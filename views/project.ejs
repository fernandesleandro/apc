<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= page.title %></title>
    <meta name="description" content="<%= page.description %>">
    <link rel="canonical" href="<%= requestUrl %>">
    <meta property="og:title" content="<%= page.title %>">
    <meta property="og:description" content="<%= page.description %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= requestUrl %>">
    <meta property="og:locale" content="pt_BR">
    <%- include('includes/meta-og') %>
    <link rel="stylesheet" href="/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fancyapps/ui/dist/fancybox/fancybox.css" />
    <% if (typeof schemaJson !== 'undefined' && schemaJson) { %>
    <script type="application/ld+json"><%- schemaJson %></script>
    <% } %>
</head>
<body>
    <a href="#main-content" class="skip-link">Pular para o conteúdo</a>
    <%- include('includes/header', { nav, active }) %>

    <main id="main-content">

    <% const defaultHeroImage = '/images/banners/banner-empreendimento.webp'; %>
    <section class="detail-hero" style="background: linear-gradient(rgba(0,17,44,0.35), rgba(0,7,20,0.88)), url('<%= detailData.heroImage || (page.hero && page.hero.image) || (detailData.galleryImages && detailData.galleryImages[0] && detailData.galleryImages[0].src) || defaultHeroImage %>') center/cover no-repeat;">
        <div class="detail-hero-overlay">
            <div class="container">
                <% if (detailData.detailTag) { %>
                    <span class="section-tag" style="color: var(--accent-blue);"><%= detailData.detailTag %></span>
                <% } %>
                <% if (project && project.categoryLabel) { %>
                    <span class="hero-category-pill"><%= project.categoryLabel %></span>
                <% } %>
                <h1><%= page.hero.title %></h1>
                <p class="detail-hero-lead"><%= page.hero.subtitle %></p>
            </div>
        </div>
    </section>

    <% if (detailData.summaryItems && detailData.summaryItems.length) { %>
    <div class="detail-nav-summary" id="ficha">
        <div class="container">
            <div class="summary-strip">
            <% detailData.summaryItems.forEach((item, index) => {
                const label = (item.label || '').toLowerCase();
                let iconClass = 'fas fa-info-circle';
                if (label.includes('metr') || label.includes('m²') || label.includes('m2')) iconClass = 'fas fa-ruler-combined';
                else if (label.includes('tipolog')) iconClass = 'fas fa-th-large';
                else if (label.includes('sig') || label.includes('end') || label.includes('logradouro') || label.includes('endereço') || label.includes('endereco') || label.includes('local')) iconClass = 'fas fa-map-marker-alt';
                else if (label.includes('constru') || label.includes('construção') || label.includes('construcao')) iconClass = 'fas fa-vector-square';
                else if (label.includes('terreno')) iconClass = 'fas fa-map';
                else if (label.includes('unidades') || label.includes('unidade')) iconClass = 'fas fa-building';
                else if (label.includes('vagas') || label.includes('garagem')) iconClass = 'fas fa-parking';
                else if (label.includes('perfil')) iconClass = 'fas fa-user';
            %>
                <div class="summary-item">
                    <i class="<%= iconClass %> summary-icon" aria-hidden="true"></i>
                    <div class="summary-item-body">
                        <span class="summary-item-label"><%= item.label %></span>
                        <p class="summary-item-value"><%= item.value %></p>
                    </div>
                </div>
            <% }) %>
            </div>
        </div>
    </div>
    <% } %>

    <% if (sectionsNav && sectionsNav.length > 1) { %>
    <nav class="project-section-nav" aria-label="Navegação da página do empreendimento">
        <div class="project-section-nav-scroll">
            <div class="project-section-nav-inner" role="tablist">
                <% sectionsNav.forEach(function(sec, idx) { %>
                    <a href="#<%= sec.id %>" class="project-section-nav-link<%= idx === 0 ? ' active' : '' %>" role="tab" aria-selected="<%= idx === 0 ? 'true' : 'false' %>"><%= sec.label %></a>
                <% }) %>
            </div>
        </div>
    </nav>
    <% } %>

    <section class="container detail-main-grid" id="detalhes">
        <div class="detail-desc">
            <span class="section-tag">Detalhes do Projeto</span>
            <h2><%= detailData.detailHeadline || page.hero.title %></h2>
            <p class="detail-lead"><%= page.description %></p>
            <% if (detailData.detailBullets && detailData.detailBullets.length) { %>
            <ul class="detail-bullets">
                <% detailData.detailBullets.forEach(function(bullet) { %>
                    <li><i class="fas fa-check" aria-hidden="true"></i> <%= bullet %></li>
                <% }) %>
            </ul>
            <% } %>
            <% if (typeof showSalesCta !== 'undefined' && showSalesCta) { %>
            <a href="/contato?obra=<%= encodeURIComponent(page.hero.title) %>" class="btn btn-filled">Solicitar Informações <i class="fas fa-chevron-right" style="margin-left:5px;"></i></a>
            <% } %>
        </div>
        <div class="showcase-gallery">
            <% if (detailData.galleryImages && detailData.galleryImages.length) { %>
                <% detailData.galleryImages.forEach((image, index) => { %>
                    <div class="gallery-img-item <%= index === 0 ? 'gallery-img-large' : '' %>">
                        <a href="<%= image.src %>" data-fancybox="galeria" data-caption="<%= image.alt %>">
                            <img loading="<%= index === 0 ? 'eager' : 'lazy' %>" src="<%= image.src %>" alt="<%= image.alt %>">
                        </a>
                    </div>
                <% }) %>
            <% } else {
                const showcaseSrc = detailData.heroImage || (page.hero && page.hero.image) || (project && project.image);
            %>
                <% if (showcaseSrc) { %>
                <div class="gallery-img-item gallery-img-large">
                    <img loading="eager" src="<%= showcaseSrc %>" alt="<%= page.hero.title %>">
                </div>
                <% } else { %>
                <div class="gallery-img-item gallery-img-large">
                    <img loading="eager" src="<%= defaultHeroImage %>" alt="<%= page.hero.title %>">
                </div>
                <% } %>
            <% } %>
        </div>
    </section>

    <% if ((detailData.plantaGallery && detailData.plantaGallery.length) || detailData.plantaImage) { %>
    <section class="planta-section" id="plantas">
        <div class="container">
            <div class="planta-header">
                <span class="section-tag tag-light"><%= detailData.plantaSectionTag %></span>
                <h2 class="section-title title-light"><%= detailData.plantaTitle || detailData.plantaSectionTag %></h2>
                <% if (detailData.plantaSubtitle) { %><p><%= detailData.plantaSubtitle %></p><% } %>
            </div>

            <div class="planta-wrapper">
                <div class="planta-img-box">
                    <% if (detailData.plantaGallery && detailData.plantaGallery.length) { %>
                        <div class="planta-thumbs-grid">
                            <% detailData.plantaGallery.forEach((pimg) => { %>
                                <a href="<%= pimg.src %>" class="planta-thumb" data-fancybox="plantas" data-caption="<%= pimg.alt %>">
                                    <img loading="lazy" src="<%= pimg.src %>" alt="<%= pimg.alt %>">
                                    <span class="planta-thumb-label"><%= pimg.alt %></span>
                                </a>
                            <% }) %>
                        </div>
                        <p class="planta-hint"><i class="fas fa-search-plus" aria-hidden="true"></i> Clique em uma planta para ampliar</p>
                    <% } else if (detailData.plantaImage) { %>
                        <a href="<%= detailData.plantaImage %>" data-fancybox="plantas">
                            <img src="<%= detailData.plantaImage %>" alt="Planta arquitetônica" style="width:100%; height:auto; border-radius:8px;">
                        </a>
                    <% } %>
                </div>
                <div class="planta-details-card">
                    <h3><%= detailData.plantaTitle || page.hero.title %></h3>
                    <p><%= detailData.plantaDescription %></p>
                    <ul class="spec-list">
                        <% (detailData.plantaHighlights || []).forEach(item => {
                            const text = (item || '').toLowerCase();
                            let icon = 'fas fa-check-circle';
                            if (text.includes('área') || text.includes('metr') || text.includes('m²')) icon = 'fas fa-ruler-combined';
                            else if (text.includes('suíte') || text.includes('suite') || text.includes('quarto') || text.includes('sala')) icon = 'fas fa-door-open';
                            else if (text.includes('cozinha') || text.includes('gourmet')) icon = 'fas fa-utensils';
                            else if (text.includes('vaga') || text.includes('garagem')) icon = 'fas fa-car';
                            else if (text.includes('lobby') || text.includes('comercial')) icon = 'fas fa-building';
                        %>
                            <li><i class="<%= icon %>" aria-hidden="true"></i> <%= item %></li>
                        <% }) %>
                    </ul>
                </div>
            </div>
        </div>
    </section>
    <% } %>

    <% if (detailData.commonAreas && detailData.commonAreas.length) { %>
    <section class="common-areas-section" id="areas">
        <div class="container">
            <div class="section-header section-header-center">
                <span class="section-tag"><%= detailData.commonAreasSectionTag %></span>
                <h2 class="section-title"><%= detailData.commonAreasTitle %></h2>
                <% if (detailData.commonAreasIntro) { %>
                    <p class="section-intro"><%= detailData.commonAreasIntro %></p>
                <% } %>
            </div>
            <div class="common-grid">
                <% detailData.commonAreas.forEach(area => { %>
                    <div class="common-item">
                        <i class="<%= area.icon %>" aria-hidden="true"></i>
                        <span><%= area.label %></span>
                    </div>
                <% }) %>
            </div>
        </div>
    </section>
    <% } %>

    <% if (detailData.location && (detailData.location.description || (detailData.location.features && detailData.location.features.length))) { %>
    <section class="location-section" id="localizacao">
        <div class="container">
            <div class="section-header location-header-block">
                <span class="section-tag"><%= detailData.location.title %></span>
                <h2 class="section-title"><%= detailData.location.subtitle %></h2>
                <p class="section-intro"><%= detailData.location.description %></p>
            </div>
            <% if (detailData.location.features && detailData.location.features.length) { %>
            <div class="location-grid">
                <% detailData.location.features.forEach(feat => { %>
                    <div class="location-card">
                        <div class="location-icon-circle"><i class="<%= feat.icon %>" aria-hidden="true"></i></div>
                        <h4><%= feat.label %></h4>
                        <p><%= feat.value %></p>
                        <% if (feat.detail) { %><p class="location-card-detail"><%= feat.detail %></p><% } %>
                    </div>
                <% }) %>
            </div>
            <% } %>
            <% if (detailData.location.mapQuery) { %>
            <div class="location-map-wrap">
                <iframe title="Mapa — <%= page.hero.title %>" width="100%" height="360" style="border:0;" loading="lazy" allowfullscreen
                    src="https://maps.google.com/maps?q=<%= encodeURIComponent(detailData.location.mapQuery) %>&t=&z=15&ie=UTF8&iwloc=&output=embed"></iframe>
                <a class="map-directions-link" href="https://www.google.com/maps/search/?api=1&query=<%= encodeURIComponent(detailData.location.mapQuery) %>" target="_blank" rel="noopener">
                    <i class="fas fa-directions" aria-hidden="true"></i> Como chegar
                </a>
            </div>
            <% } %>
        </div>
    </section>
    <% } %>

    <% if (typeof showSalesCta !== 'undefined' && showSalesCta) { %>
    <section class="project-bottom-cta">
        <div class="container project-bottom-cta-inner">
            <h3>Interessado em <%= page.hero.title %>?</h3>
            <p>Fale com nossa equipe comercial e receba plantas, tabela e condições.</p>
            <div class="detail-cta-row">
                <a href="/contato?obra=<%= encodeURIComponent(page.hero.title) %>" class="btn btn-filled">Agendar conversa</a>
                <a href="<%= whatsappUrl %>" class="btn btn-outline-white" target="_blank" rel="noopener">WhatsApp direto</a>
            </div>
        </div>
    </section>
    <% } %>

    </main>

    <%- include('includes/footer', { footer }) %>

    <% if (typeof showSalesCta !== 'undefined' && showSalesCta) { %>
    <a href="<%= whatsappUrl %>" class="whatsapp-float" target="_blank" rel="noopener" aria-label="WhatsApp">
        <i class="fab fa-whatsapp"></i>
    </a>
    <% } %>

    <script src="https://cdn.jsdelivr.net/npm/@fancyapps/ui/dist/fancybox/fancybox.umd.js"></script>
    <script>
        Fancybox.bind("[data-fancybox='galeria'], [data-fancybox='plantas']", {
            Toolbar: true,
            Images: { zoom: false },
            dragToClose: true,
            animated: true
        });
    </script>
    <script src="/main.js"></script>
</body>
</html>
