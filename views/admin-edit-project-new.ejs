                    <div id="galleryGallery" class="gallery-container">
                        <div class="empty-gallery">Nenhuma imagem enviada ainda</div>
                    </div>
                </div>

                <div class="btn-group">
                    <button type="button" id="uploadGalleryBtn" class="btn-upload" style="display: inline-block !important;"><i class="fas fa-check"></i> Upload de Imagens</button>
                    <button type="button" id="saveGalleryBtn" class="btn-primary"><i class="fas fa-save"></i> Salvar Galeria</button>
