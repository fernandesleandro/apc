        <!-- TAB: GALERIA GERAL -->
        <div id="gallery" class="tab-content">
            <div class="form-card">
                <div class="section">
                    <h3><i class="fas fa-image"></i> Galeria do Projeto</h3>
                    <p style="color: #718096; margin-bottom: 20px; font-size: 0.95rem;">Imagens gerais, detalhes construtivos e vistas do empreendimento. As imagens serão armazenadas em <code style="background: #eef2ff; padding: 2px 6px; border-radius: 4px; color: #0073ff;">/images/gallery/<%= project.id %>/</code></p>

