                        <div class="form-group form-row full">
                            <label for="plantaTitle">Título da Seção (H2)</label>
                            <input type="text" id="plantaTitle" name="plantaTitle" placeholder="Ex: Distribuição de Espaços" value="<%= page && page.details && page.details.plantaTitle ? page.details.plantaTitle : 'Distribuição de Espaços' %>">
