                } else {
                    showMessage(data.message, 'error');
                }
            } catch (error) {
                console.error('Erro:', error);
                showMessage('Erro ao salvar: ' + error.message, 'error');
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="fas fa-save"></i> Salvar Informações Técnicas';
            }
        });

        // ===== FORM: LOCALIZAÇÃO =====
        document.getElementById('locationForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const submitBtn = e.target.querySelector('button[type="submit"]');
            submitBtn.disabled = true;
            submitBtn.textContent = 'Salvando...';

            const formData = {
                address: document.getElementById('address').value,
                locationTitle: document.getElementById('locationTitle').value,
                locationSubtitle: document.getElementById('locationSubtitle').value,
                locationMapQuery: document.getElementById('locationMapQuery').value,
                locationDescription: document.getElementById('locationDescription').value,
                locationFeatures: collectLocationFeatures()
            };

            try {
                const response = await fetch(`/admin/update-location-info/${projectId}`, {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                    body: JSON.stringify(formData)
                });
                const data = await parseApiJson(response);

                if (data.success) {
                    showMessage(data.message, 'success');
                } else {
                    showMessage(data.message, 'error');
                }
            } catch (error) {
                console.error('Erro:', error);
                showMessage('Erro ao salvar: ' + error.message, 'error');
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="fas fa-save"></i> Salvar Localização';
            }
        });

        // ===== FORM: ÁREAS COMUNS =====
        document.getElementById('commonAreasForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const submitBtn = e.target.querySelector('button[type="submit"]');
            submitBtn.disabled = true;
            submitBtn.textContent = 'Salvando...';

            const parsedCommonAreas = collectCommonAreas();

            try {
                const response = await fetch(`/admin/update-common-areas/${projectId}`, {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                    body: JSON.stringify({
                        commonAreasSectionTag: document.getElementById('commonAreasSectionTag').value,
                        commonAreasTitle: document.getElementById('commonAreasTitle').value,
                        commonAreasIntro: document.getElementById('commonAreasIntro').value,
                        commonAreas: parsedCommonAreas
                    })
                });
                const data = await parseApiJson(response);

                if (data.success) {
                    showMessage(data.message, 'success');
                } else {
                    showMessage(data.message, 'error');
                }
            } catch (error) {
                console.error('Erro:', error);
                showMessage('Erro ao salvar: ' + error.message, 'error');
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="fas fa-save"></i> Salvar Áreas Comuns';
            }
        });

        // ===== FUNÇÃO GENÉRICA DE UPLOAD =====
        async function uploadFilesGeneric(filesArray, endpoint, previewContainerId, galleryCB) {
            if (!filesArray || filesArray.length === 0) {
                Swal.fire('Atenção', 'Nenhuma imagem selecionada', 'warning');
                return false;
            }

            const container = document.getElementById(previewContainerId);
            const previews = container.querySelectorAll('.upload-preview-item');
            let uploadedCount = 0;
            let totalCount = filesArray.length;

            console.log(`[UPLOAD] Iniciando: ${totalCount} arquivo(s) → ${endpoint}/${projectId}`);

            for (let i = 0; i < filesArray.length; i++) {
                const file = filesArray[i];
                const preview = previews[i];

                if (!preview) {
                    console.warn(`[UPLOAD] Preview não encontrado para índice ${i}`);
                    continue;
                }

                const altText = preview.querySelector('.alt-text')?.value.trim();
                const titleText = preview.querySelector('.title-text')?.value.trim();

                if (!altText) {
                    Swal.fire('Erro', `Descrição (alt) é obrigatória para ${file.name}`, 'error');
                    return false;
                }

                const formData = new FormData();
                formData.append('image', file);
                formData.append('alt', altText);
                formData.append('title', titleText);

                try {
                    setUploadStatus(preview, 'Carregando...', 'loading');

                    const data = await uploadFileWithProgress(`${endpoint}/${projectId}`, formData);

                    if (data.success) {
                        setUploadStatus(preview, '✓ Upload concluído', 'success');
                        uploadedCount++;
                        console.log(`[UPLOAD] ✓ ${file.name} (${uploadedCount}/${totalCount})`);
                    } else {
                        setUploadStatus(preview, '✕ Erro: ' + data.message, 'error');
                        console.error(`[UPLOAD] ✕ ${file.name}: ${data.message}`);
                    }
                } catch (error) {
                    setUploadStatus(preview, '✕ Erro: ' + error.message, 'error');
                    console.error(`[UPLOAD] ✕ ${file.name}:`, error.message);
                }
            }

            console.log(`[UPLOAD] Fim: ${uploadedCount}/${totalCount} arquivo(s)`);

            if (uploadedCount === totalCount && uploadedCount > 0) {
                setTimeout(() => {
                    showMessage('Todas as imagens foram carregadas com sucesso!', 'success');
                    filesArray.length = 0;
                    container.innerHTML = '';
                    if (galleryCB) galleryCB();
                }, 500);
                return true;
            }

            if (uploadedCount > 0 && uploadedCount < totalCount) {
                showMessage(`${uploadedCount} de ${totalCount} imagem(ns) carregada(s).`, 'error');
            }

            return uploadedCount === totalCount;
        }

        // ===== UPLOAD: PLANTAS =====
        document.getElementById('uploadPlantaBtn').addEventListener('click', async () => {
            const btn = document.getElementById('uploadPlantaBtn');
            btn.disabled = true;
            btn.textContent = 'Enviando...';
            
            await uploadFilesGeneric(selectedFilesPlanta, '/admin/upload-planta', 'plantaPreviewContainer', loadPlantaGallery);
            
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-check"></i> Upload de Imagens';
        });

        // ===== UPLOAD: GALERIA GERAL =====
        async function uploadGalleryFiles() {
            try {
                const ensureResp = await fetch(`/admin/ensure-project-folders/${projectId}`, { method: 'POST', credentials: 'same-origin' });
                if (!ensureResp.ok) {
                    console.warn('[UPLOAD] ensure-project-folders responded with', ensureResp.status);
                }
            } catch (err) {
                console.error('[UPLOAD] Falha ao garantir pastas do projeto:', err);
            }

            const galleryInputEl = document.getElementById('galleryInput');
            if (selectedFilesGallery.length === 0 && galleryInputEl?.files?.length > 0) {
                console.log('[UPLOAD] Preenchendo selectedFilesGallery a partir de galleryInput.files (fallback)');
                for (const f of galleryInputEl.files) {
                    displayFilePreview(f, document.getElementById('galleryPreviewContainer'), selectedFilesGallery);
                }
            }

            return await uploadFilesGeneric(selectedFilesGallery, '/admin/upload-gallery', 'galleryPreviewContainer', loadGeneralGallery);
        }

        const uploadGalleryBtn = document.getElementById('uploadGalleryBtn');
        const saveGalleryBtn = document.getElementById('saveGalleryBtn');

        if (uploadGalleryBtn) {
            uploadGalleryBtn.addEventListener('click', async () => {
                uploadGalleryBtn.disabled = true;
                uploadGalleryBtn.textContent = 'Enviando...';
                await uploadGalleryFiles();
                uploadGalleryBtn.disabled = false;
                uploadGalleryBtn.innerHTML = '<i class="fas fa-check"></i> Upload de Imagens';
            });
        }

        if (saveGalleryBtn) {
            saveGalleryBtn.addEventListener('click', async () => {
                saveGalleryBtn.disabled = true;
                saveGalleryBtn.textContent = 'Salvando...';
                
                // Se houver arquivos pendentes, faz o upload primeiro
                if (selectedFilesGallery.length > 0) {
                    const success = await uploadGalleryFiles();
                    if (success) {
                        showMessage('Galeria salva com sucesso!', 'success');
                    }
                } else {
                    // Apenas recarrega a galeria e confirma
                    await loadGeneralGallery();
                    showMessage('Galeria salva com sucesso!', 'success');
                }
                
                saveGalleryBtn.disabled = false;
                saveGalleryBtn.innerHTML = '<i class="fas fa-save"></i> Salvar Galeria';
            });
        }

        // ===== CARREGAR GALERIAS =====
        async function loadPlantaGallery() {
            try {
                const galleryEl = document.getElementById('plantaGallery');
                
                // Fetch data would happen here, for now we'll show empty state
                fetch(`/admin/get-planta-gallery/${projectId}`, { credentials: 'same-origin' })
                    .then(r => r.json())
                    .then(data => {
                        if (data.images && data.images.length > 0) {
                            galleryEl.innerHTML = data.images.map(img => `
                                <div class="gallery-item">
                                    <img src="${img.src}" alt="${img.alt}">
                                    <div class="gallery-item-overlay">
                                        <button onclick="deletePlantaImage('${img.src.split('/').pop().split('?')[0]}')">
                                            <i class="fas fa-trash"></i> Deletar
                                        </button>
                                    </div>
                                </div>
                            `).join('');
                        } else {
                            galleryEl.innerHTML = '<div class="empty-gallery">Nenhuma imagem enviada ainda</div>';
                        }
                    })
                    .catch(err => {
                        galleryEl.innerHTML = '<div class="empty-gallery">Erro ao carregar galeria</div>';
                    });
            } catch (error) {
                console.error('Erro ao carregar galeria de planta:', error);
            }
        }

        async function loadGeneralGallery() {
            try {
                const galleryEl = document.getElementById('galleryGallery');
                
                fetch(`/admin/get-gallery/${projectId}`, { credentials: 'same-origin' })
                    .then(r => r.json())
                    .then(data => {
                        if (data.images && data.images.length > 0) {
                            galleryEl.innerHTML = data.images.map(img => `
                                <div class="gallery-item">
                                    <img src="${img.src}" alt="${img.alt}">
                                    <div class="gallery-item-overlay">
                                        <button onclick="deleteGalleryImage('${img.src.split('/').pop().split('?')[0]}')">
                                            <i class="fas fa-trash"></i> Deletar
                                        </button>
                                    </div>
                                </div>
                            `).join('');
                        } else {
                            galleryEl.innerHTML = '<div class="empty-gallery">Nenhuma imagem enviada ainda</div>';
                        }
                    })
                    .catch(err => {
                        galleryEl.innerHTML = '<div class="empty-gallery">Erro ao carregar galeria</div>';
                    });
            } catch (error) {
                console.error('Erro ao carregar galeria geral:', error);
            }
        }

        async function deletePlantaImage(filename) {
            const result = await Swal.fire({
                title: 'Confirmar exclusão',
                text: 'Deseja remover esta imagem?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e53e3e',
                confirmButtonText: 'Sim, deletar'
            });

            if (result.isConfirmed) {
                try {
                    const response = await fetch(`/admin/delete-planta-image/${projectId}/${filename}`, {
                        method: 'POST',
                        credentials: 'same-origin',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });
                    const data = await parseApiJson(response);

                    if (data.success) {
                        showMessage('Imagem deletada com sucesso!', 'success');
                        loadPlantaGallery();
                    } else {
                        showMessage('Erro ao deletar imagem', 'error');
                    }
                } catch (error) {
                    showMessage('Erro ao deletar: ' + error.message, 'error');
                }
            }
        }

        async function deleteGalleryImage(filename) {
            const result = await Swal.fire({
                title: 'Confirmar exclusão',
                text: 'Deseja remover esta imagem?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e53e3e',
                confirmButtonText: 'Sim, deletar'
            });

            if (result.isConfirmed) {
                try {
                    const response = await fetch(`/admin/delete-gallery-image/${projectId}/${filename}`, {
                        method: 'POST',
                        credentials: 'same-origin',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });
                    const data = await parseApiJson(response);

                    if (data.success) {
                        showMessage('Imagem deletada com sucesso!', 'success');
                        loadGeneralGallery();
                    } else {
                        showMessage('Erro ao deletar imagem', 'error');
                    }
                } catch (error) {
                    showMessage('Erro ao deletar: ' + error.message, 'error');
                }
            }
        }

        // ===== INICIALIZAÇÃO =====
        async         function setupAdminBackLinks() {
            document.querySelectorAll('[data-admin-back]').forEach((link) => {
                link.addEventListener('click', (e) => {
                    const ref = document.referrer || '';
                    if (ref.includes('/admin/dashboard')) {
                        e.preventDefault();
                        window.location.assign('/admin/dashboard');
                    }
                });
            });
        }

        function init() {
            loadPlantaGallery();
            loadGeneralGallery();
            renderTechnicalItems(initialTechnicalSummaryItems);
            setupAdminBackLinks();

            document.getElementById('toggleDetailBulletsHelp')?.addEventListener('click', () => {
                document.getElementById('detailBulletsHelpPanel')?.classList.toggle('is-open');
            });

            const hash = window.location.hash.replace('#', '');
            if (hash) {
                const tabBtn = document.querySelector(`.tab-btn[data-tab="${hash}"]`);
                if (tabBtn) tabBtn.click();
            }
        }

        init();
    </script>
</body>
