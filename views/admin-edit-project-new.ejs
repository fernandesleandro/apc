                        <p style="color: #718096; margin-bottom: 20px; font-size: 0.95rem;">As imagens serão armazenadas em <code style="background: #eef2ff; padding: 2px 6px; border-radius: 4px; color: #0073ff;">/images/planta/<%= project.id %>/</code></p>

                        <div class="drop-area" id="plantaDropArea">
                            <i class="fas fa-cloud-upload-alt"></i>
                            <p><strong>Arraste imagens aqui</strong></p>
                            <p class="small">ou clique para selecionar (máximo 50MB cada)</p>
                        </div>
                        <input type="file" id="plantaInput" style="display: none;" multiple accept="image/*">

                        <div id="plantaPreviewContainer" class="upload-preview-container"></div>
                    </div>

                    <div id="plantaGalleryContainer" class="section">
                        <h3><i class="fas fa-photo-film"></i> Imagens Enviadas</h3>
                        <div id="plantaGallery" class="gallery-container">
                            <div class="empty-gallery">Nenhuma imagem enviada ainda</div>
                        </div>
                    </div>

                    <div class="btn-group">
                        <button type="submit" class="btn-primary"><i class="fas fa-save"></i> Salvar Detalhes da Planta</button>
                        <button type="button" id="uploadPlantaBtn" class="btn-upload"><i class="fas fa-check"></i> Upload de Imagens</button>
                    </div>
                </form>
            </div>
        </div>

