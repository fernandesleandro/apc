    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // ===== VARIÁVEIS GLOBAIS =====
        const projectId = '<%= project.id %>';
        const selectedFilesMain = [];
        const selectedFilesPlanta = [];
        const selectedFilesGallery = [];
        const initialTechnicalSummaryItems = <%- JSON.stringify((page && page.details && Array.isArray(page.details.summaryItems) ? page.details.summaryItems : []).filter(item => item && item.label !== 'Endereço')) %>;
        const initialDetailBullets = <%- JSON.stringify(page && page.details && Array.isArray(page.details.detailBullets) ? page.details.detailBullets : []) %>;
        const initialPlantaHighlights = <%- JSON.stringify(page && page.details && Array.isArray(page.details.plantaHighlights) ? page.details.plantaHighlights : []) %>;
        const initialLocationFeatures = <%- JSON.stringify(page && page.details && page.details.location && Array.isArray(page.details.location.features) ? page.details.location.features : []) %>;
        const initialCommonAreas = <%- JSON.stringify(page && page.details && Array.isArray(page.details.commonAreas) ? page.details.commonAreas : []) %>;

        const FA_ICON_PRESETS = [
            { value: 'fas fa-route', label: 'Mobilidade / Rota' },
            { value: 'fas fa-hospital-symbol', label: 'Saúde' },
            { value: 'fas fa-graduation-cap', label: 'Educação' },
            { value: 'fas fa-store', label: 'Comércio' },
            { value: 'fas fa-palette', label: 'Cultura / Lazer' },
            { value: 'fas fa-car', label: 'Estacionamento' },
            { value: 'fas fa-building', label: 'Edifício / Corporativo' },
            { value: 'fas fa-shield-alt', label: 'Segurança' },
            { value: 'fas fa-elevator', label: 'Elevador' },
            { value: 'fas fa-dumbbell', label: 'Academia' },
            { value: 'fas fa-utensils', label: 'Gourmet' },
            { value: 'fas fa-swimmer', label: 'Piscina' },
            { value: 'fas fa-users', label: 'Convivência' },
            { value: 'fas fa-network-wired', label: 'TI / Redes' },
            { value: 'fas fa-sun', label: 'Área externa' },
            { value: 'fas fa-door-open', label: 'Lobby / Salas' },
            { value: 'fas fa-eye', label: 'Visibilidade' },
            { value: 'fas fa-parking', label: 'Vagas' },
            { value: 'fas fa-check', label: 'Genérico (check)' }
        ];

        function isPresetIcon(icon) {
            return FA_ICON_PRESETS.some(p => p.value === icon);
        }

        function buildIconSelectMarkup(selectedIcon = 'fas fa-check') {
            const isCustom = selectedIcon && !isPresetIcon(selectedIcon);
            const options = FA_ICON_PRESETS.map(p =>
