<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= page.title %></title>
    <meta name="description" content="<%= page.description %>">
    <link rel="canonical" href="<%= requestUrl %>">
    <meta property="og:title" content="<%= page.title %>">
    <meta property="og:description" content="<%= page.description %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= requestUrl %>">
    <meta property="og:locale" content="pt_BR">
    <%- include('includes/meta-og') %>
    <link rel="stylesheet" href="/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <a href="#main-content" class="skip-link">Pular para o conteúdo</a>
    <%- include('includes/header', { nav, active }) %>

    <main id="main-content">

    <section class="page-banner page-banner--atendimento">
        <div class="container">
            <h1><%= page.hero.title %></h1>
            <p><%= page.hero.subtitle %></p>
        </div>
    </section>

    <section class="container contact-layout">
        <div class="form-wrapper">
            <h2>Fale Conosco</h2>
            <% if (typeof projectInterest !== 'undefined' && projectInterest) { %>
                <p class="contact-interest-banner"><i class="fas fa-building" aria-hidden="true"></i> Interesse em: <strong><%= projectInterest %></strong></p>
            <% } %>
            <form id="contactForm" novalidate>
                <div class="form-honeypot" aria-hidden="true">
                    <label for="website">Website</label>
                    <input type="text" id="website" name="website" tabindex="-1" autocomplete="off">
                </div>
                <div class="form-group">
                    <label for="nome">Nome</label>
                    <input type="text" id="nome" name="nome" placeholder="Seu nome completo" required autocomplete="name">
                </div>
                <div class="form-group">
                    <label for="email">E-mail</label>
                    <input type="email" id="email" name="email" placeholder="seu@email.com" required autocomplete="email">
                </div>
                <div class="form-group">
                    <label for="telefone">Telefone</label>
                    <input type="tel" id="telefone" name="telefone" placeholder="(61) 99999-9999" autocomplete="tel">
                </div>
                <div class="form-group">
                    <label for="endereco">Endereço</label>
                    <input type="text" id="endereco" name="endereco" placeholder="Rua, bairro, cidade" autocomplete="street-address">
                </div>
                <div class="form-group">
                    <label for="interesse">Empreendimento de interesse <span class="form-optional">(opcional)</span></label>
                    <input type="text" id="interesse" name="interesse" placeholder="Ex: Monumental Center" value="<%= typeof projectInterest !== 'undefined' ? projectInterest : '' %>">
                </div>
                <div class="form-group">
                    <label for="mensagem">Mensagem</label>
                    <textarea id="mensagem" name="mensagem" rows="5" placeholder="Escreva sua mensagem..." required></textarea>
                </div>
                <p id="contactFeedback" class="form-feedback" role="status" aria-live="polite"></p>
                <button type="submit" class="btn btn-filled contact-submit-btn">Enviar <i class="fas fa-paper-plane" aria-hidden="true"></i></button>
            </form>
        </div>

        <div class="info-sidebar">
            <a href="/trabalhe-conosco" class="contact-careers-card">
                <img src="/images/banners/banner-equipe.webp" alt="Trabalhe Conosco AP Construções" loading="lazy">
                <div class="contact-careers-card-body">
                    <span class="section-tag">Carreiras</span>
                    <h3>Trabalhe Conosco</h3>
                    <p>Faça parte da equipe AP Construções.</p>
                    <span class="contact-careers-link">Ver oportunidades <i class="fas fa-arrow-right" aria-hidden="true"></i></span>
                </div>
            </a>

            <div class="info-card">
                <h3>Informações de Contato</h3>
                <% const contacts = ((footer && footer.contact && footer.contact.length) ? footer.contact : [
                    { icon: 'fas fa-phone-alt', label: 'Telefone', value: '(61) 2195-8300' },
                    { icon: 'fas fa-envelope', label: 'E-mail', value: 'contato@apconstrucoes.com.br' },
                    { icon: 'fas fa-map-marker-alt', label: 'Endereço', value: 'SCS Qd. 02 Bl. D Ed. Oscar Niemeyer, 13° andar, Sala 1301 - Brasília/DF' }
                ]).filter(function(item) { return !(item.icon || '').includes('whatsapp'); }); %>
                <% contacts.forEach(function(item) {
                    const title = item.label || 'Contato';
                %>
                <div class="info-row">
                    <i class="<%= item.icon %>"></i>
                    <div>
                        <h4><%= title %></h4>
                        <p><%= item.value %></p>
                    </div>
                </div>
                <% }) %>
            </div>

            <% const mapQuery = encodeURIComponent('Edificio Oscar Niemeyer Brasilia'); %>
            <div class="map-box">
                <iframe title="Mapa da sede AP Construções" width="100%" height="100%" style="border:0;" loading="lazy" allowfullscreen
                    src="https://maps.google.com/maps?q=<%= mapQuery %>&t=&z=15&ie=UTF8&iwloc=&output=embed"></iframe>
            </div>
        </div>
    </section>

    </main>

    <%- include('includes/footer', { footer }) %>

    <a href="<%= typeof whatsappUrl !== 'undefined' ? whatsappUrl : 'https://api.whatsapp.com/send?phone=556121958300' %>" class="whatsapp-float" target="_blank" rel="noopener" aria-label="WhatsApp">
        <i class="fab fa-whatsapp"></i>
    </a>

    <script src="/main.js"></script>
</body>
</html>
