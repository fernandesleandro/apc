<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Admin | AP Construções</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/admin.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Montserrat', sans-serif;
            background: linear-gradient(135deg, #0073ff 0%, #005bc2 50%, #00112c 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .login-container {
            background: white;
            border-radius: 16px;
            box-shadow: 0 25px 70px rgba(0,0,0,0.35), 0 5px 15px rgba(0,0,0,0.1);
            padding: 50px;
            width: 100%;
            max-width: 420px;
            animation: slideUp 0.5s ease-out;
        }
        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .login-header {
            text-align: center;
            margin-bottom: 40px;
        }
        .login-header h1 {
            font-size: 2rem;
            color: #00112c;
            margin-bottom: 8px;
            font-weight: 800;
            letter-spacing: 0.5px;
        }
        .login-header p {
            color: #64748b;
            font-size: 0.95rem;
            font-weight: 400;
        }
        .form-group {
            margin-bottom: 20px;
        }
        label {
            display: block;
            margin-bottom: 8px;
            color: #2d3748;
            font-weight: 600;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        input {
            width: 100%;
            padding: 14px 16px;
            border: 1.5px solid #e2e8f0;
            border-radius: 8px;
            font-family: 'Montserrat', sans-serif;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            background: #f8fafc;
        }
        input:focus {
            outline: none;
            border-color: #0073ff;
            background: white;
            box-shadow: 0 0 0 4px rgba(0, 115, 255, 0.1);
        }
        .error-message {
            background: #fecaca;
            color: #991b1b;
            padding: 14px 16px;
            border-radius: 8px;
            margin-bottom: 20px;
            display: none;
            font-size: 0.9rem;
            border: 1px solid #fca5a5;
            border-left: 4px solid #dc2626;
        }
        .error-message.show {
            display: block;
            animation: shake 0.3s ease-in-out;
        }
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-5px); }
            75% { transform: translateX(5px); }
        }
        button {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #0073ff 0%, #005bc2 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-family: 'Montserrat', sans-serif;
            font-weight: 700;
            font-size: 0.95rem;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 8px 20px rgba(0, 115, 255, 0.3);
        }
        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 30px rgba(0, 115, 255, 0.4);
        }
        button:active {
            transform: translateY(0);
        }
        .divider {
            text-align: center;
            color: #cbd5e1;
            margin-top: 20px;
            font-size: 0.9rem;
        }
        .info-box {
            background: #edf2f7;
            border-left: 4px solid #667eea;
            padding: 12px;
            border-radius: 4px;
            margin-top: 20px;
            font-size: 0.85rem;
            color: #2d3748;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-header">
            <div class="login-brand-wrap">
                <%- include('includes/admin-brand', { variant: 'dark', subtitle: 'Painel administrativo', link: '/' }) %>
            </div>
        </div>

        <% if (error) { %>
            <div class="error-message show">
                <% if (error === 'invalid') { %>
                    Usuário ou senha inválidos
                <% } else if (error === 'server') { %>
                    Erro ao conectar. Tente novamente.
                <% } %>
            </div>
        <% } %>

        <form method="POST" action="/admin/login">
            <div class="form-group">
                <label for="username">Usuário</label>
                <input type="text" id="username" name="username" required placeholder="Seu usuário">
            </div>

            <div class="form-group">
                <label for="password">Senha</label>
                <input type="password" id="password" name="password" required placeholder="Sua senha">
            </div>

            <button type="submit">Entrar</button>
        </form>

        
    </div>
</body>
</html>
