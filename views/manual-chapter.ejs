<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= chapter.title %> — <%= chapter.sectionTitle %> | AP Construções</title>
    <meta name="description" content="<%= chapter.title %> — Manual do Proprietário, <%= chapter.sectionTitle %>">
    <link rel="canonical" href="<%= requestUrl %>">
    <link rel="stylesheet" href="/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

    <%- include('includes/header', { nav, active }) %>

    <section class="page-banner page-banner--compact">
        <div class="container">
            <p class="manual-reader-eyebrow"><%= chapter.sectionTitle %></p>
            <h1><%= chapter.title %></h1>
            <p class="manual-reader-subtitle"><%= chapter.docTitle %></p>
        </div>
    </section>

    <section class="manual-reader-section">
        <div class="container">
            <nav class="manual-reader-nav" aria-label="Navegação do manual">
                <a href="/acesso-cliente/manual-proprietario" class="manual-reader-back">
                    <i class="fas fa-arrow-left" aria-hidden="true"></i> Todos os manuais
                </a>
                <a href="/acesso-cliente/manual-proprietario#manual-<%= chapter.sectionSlug %>" class="manual-reader-back manual-reader-back--secondary">
                    <i class="fas fa-building" aria-hidden="true"></i> <%= chapter.sectionTitle %>
                </a>
            </nav>

            <% if (prevChapter || nextChapter) { %>
            <div class="manual-reader-pager manual-reader-pager--top">
                <% if (prevChapter) { %>
                <a href="<%= prevChapter.path %>" class="manual-reader-pager-link manual-reader-pager-link--prev">
                    <span class="manual-reader-pager-label">Anterior</span>
                    <span class="manual-reader-pager-title"><%= prevChapter.title %></span>
                </a>
                <% } else { %><span></span><% } %>
                <% if (nextChapter) { %>
                <a href="<%= nextChapter.path %>" class="manual-reader-pager-link manual-reader-pager-link--next">
                    <span class="manual-reader-pager-label">Próximo</span>
                    <span class="manual-reader-pager-title"><%= nextChapter.title %></span>
                </a>
                <% } %>
            </div>
            <% } %>

            <article class="manual-reader-content">
                <%- chapter.html %>
            </article>

            <% if (prevChapter || nextChapter) { %>
            <div class="manual-reader-pager manual-reader-pager--bottom">
                <% if (prevChapter) { %>
                <a href="<%= prevChapter.path %>" class="manual-reader-pager-link manual-reader-pager-link--prev">
                    <span class="manual-reader-pager-label">Anterior</span>
                    <span class="manual-reader-pager-title"><%= prevChapter.title %></span>
                </a>
                <% } else { %><span></span><% } %>
                <% if (nextChapter) { %>
                <a href="<%= nextChapter.path %>" class="manual-reader-pager-link manual-reader-pager-link--next">
                    <span class="manual-reader-pager-label">Próximo</span>
                    <span class="manual-reader-pager-title"><%= nextChapter.title %></span>
                </a>
                <% } %>
            </div>
            <% } %>
        </div>
    </section>

    <%- include('includes/footer', { footer }) %>

    <a href="<%= typeof whatsappUrl !== 'undefined' ? whatsappUrl : 'https://api.whatsapp.com/send?phone=556121958300' %>" class="whatsapp-float" target="_blank" rel="noopener" aria-label="WhatsApp">
        <i class="fab fa-whatsapp"></i>
    </a>
    <script src="/main.js"></script>
</body>
</html>
