<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= page.title %></title>
    <meta name="description" content="<%= page.description %>">
    <link rel="canonical" href="<%= requestUrl %>">
    <meta property="og:title" content="<%= page.title %>">
    <meta property="og:description" content="<%= page.description %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= requestUrl %>">
    <meta property="og:locale" content="pt_BR">
    <%- include('includes/meta-og') %>
    <link rel="stylesheet" href="/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

    <%- include('includes/header', { nav, active }) %>

    <section class="page-banner" style="background: linear-gradient(rgba(0,11,44,0.88), rgba(0,7,20,0.96)), url('https://images.unsplash.com/photo-1556761175-4b46a572b786?auto=format&fit=crop&w=1920&q=80') center/cover no-repeat;">
        <div class="container">
            <h1><%= page.hero.title %></h1>
            <p><%= page.hero.subtitle %></p>
        </div>
    </section>

    <section class="client-docs-section<%= typeof isManualHub !== 'undefined' && isManualHub ? ' client-docs-section--manual' : '' %>">
        <div class="container">
            <div class="client-docs-intro">
                <% if (page.content && page.content.intro) { %>
                    <p><%= page.content.intro %></p>
                <% } %>
                <% if (page.content && page.content.backHref) { %>
                    <a href="<%= page.content.backHref %>" class="client-docs-back"><i class="fas fa-arrow-left" aria-hidden="true"></i> <%= page.content.backLabel || 'Voltar' %></a>
                <% } %>
            </div>

            <% if (typeof isManualHub !== 'undefined' && isManualHub && page.content && page.content.sections && page.content.sections.length) { %>
            <% const manualDocMeta = {
                proprietario: { icon: 'fa-book-open', badge: 'Unidade', action: 'Abrir manual', hint: 'Uso, manutenção e garantias da sua unidade' },
                'areas-comuns': { icon: 'fa-building', badge: 'Condomínio', action: 'Abrir manual', hint: 'Áreas comuns, elevadores e regras do edifício' },
                desenhos: { icon: 'fa-drafting-compass', badge: 'Desenhos', action: 'Ver desenhos', hint: 'Plantas e desenhos orientativos' },
                'habite-se': { icon: 'fa-file-pdf', badge: 'PDF', action: 'Baixar PDF', hint: 'Documento oficial de habite-se' },
                documento: { icon: 'fa-file-lines', badge: 'Documento', action: 'Abrir', hint: '' }
            }; %>

            <div class="manual-hub-toolbar">
                <div class="manual-hub-search-wrap">
                    <i class="fas fa-search" aria-hidden="true"></i>
                    <input type="search" id="manualHubSearch" class="manual-hub-search" placeholder="Buscar empreendimento ou capítulo…" autocomplete="off" aria-label="Buscar empreendimento ou capítulo">
                </div>
                <p class="manual-hub-count" id="manualHubCount"><%= page.content.sections.length %> empreendimentos</p>
            </div>

            <div class="manual-hub-jump" id="manualHubJump" aria-label="Ir para empreendimento">
                <% page.content.sections.forEach(function(section) { %>
                    <a href="#manual-<%= section.slug %>" class="manual-hub-jump-link"><%= section.title %></a>
                <% }) %>
            </div>

            <p class="manual-hub-note"><i class="fas fa-sitemap" aria-hidden="true"></i> Abra o manual e clique no tópico na árvore para ler. PDFs de habite-se abrem em nova aba.</p>

            <div class="manual-hub-list" id="manualHubList">
                <% page.content.sections.forEach(function(section, index) {
                    const sectionKeywords = [section.title.toLowerCase()];
                    (section.documents || []).forEach(function(doc) {
                        (doc.children || []).forEach(function(ch) {
                            sectionKeywords.push(String(ch.title || '').toLowerCase());
                        });
                    });
                %>
                <article class="manual-hub-card" id="manual-<%= section.slug %>" data-manual-title="<%= section.title.toLowerCase() %>" data-manual-keywords="<%= sectionKeywords.join(' ') %>">
                    <button type="button" class="manual-hub-card-toggle" aria-expanded="<%= index === 0 ? 'true' : 'false' %>" aria-controls="manual-panel-<%= section.slug %>">
                        <span class="manual-hub-card-title"><%= section.title %></span>
                        <% const chapterCount = (section.documents || []).reduce(function(n, d) { return n + (d.children || []).length; }, 0); %>
                        <span class="manual-hub-card-meta"><%= (section.documents || []).length %> manual<%= (section.documents || []).length === 1 ? '' : 'is' %><% if (chapterCount) { %> · <%= chapterCount %> capítulos<% } %></span>
                        <i class="fas fa-chevron-down manual-hub-card-chevron" aria-hidden="true"></i>
                    </button>
                    <div class="manual-hub-card-panel" id="manual-panel-<%= section.slug %>"<%= index === 0 ? '' : ' hidden' %>>
                        <% (section.documents || []).forEach(function(doc) {
                            const docType = doc.type || 'documento';
                            const meta = manualDocMeta[docType] || manualDocMeta.documento;
                            const isPdf = docType === 'habite-se' || /\.pdf($|\?)/i.test(doc.href || '');
                            const hasManual = !isPdf && (doc.chapterCount || (doc.children || []).length) > 0;
                        %>
                        <% if (hasManual) { %>
                        <a href="<%= doc.internalPath %>" class="manual-hub-doc manual-hub-doc--<%= docType %>">
                            <span class="manual-hub-doc-icon"><i class="fas <%= meta.icon %>" aria-hidden="true"></i></span>
                            <span class="manual-hub-doc-body">
                                <span class="manual-hub-doc-title"><%= doc.title %></span>
                                <% if (meta.hint) { %><span class="manual-hub-doc-hint"><%= meta.hint %></span><% } %>
                                <span class="manual-hub-doc-chapter-count"><%= doc.chapterCount || (doc.children || []).length %> tópico<%= (doc.chapterCount || (doc.children || []).length) === 1 ? '' : 's' %> · página única</span>
                            </span>
                            <span class="manual-hub-doc-badge"><%= meta.badge %></span>
                            <span class="manual-hub-doc-action">Ler manual <i class="fas fa-chevron-right" aria-hidden="true"></i></span>
                        </a>
                        <% } else { %>
                        <a href="<%= doc.href %>" class="manual-hub-doc manual-hub-doc--<%= docType %>" target="_blank" rel="noopener noreferrer">
                            <span class="manual-hub-doc-icon<%= isPdf ? ' is-pdf' : '' %>"><i class="fas <%= meta.icon %>" aria-hidden="true"></i></span>
                            <span class="manual-hub-doc-body">
                                <span class="manual-hub-doc-title"><%= doc.title %></span>
                                <% if (meta.hint) { %><span class="manual-hub-doc-hint"><%= meta.hint %></span><% } %>
                            </span>
                            <span class="manual-hub-doc-badge"><%= meta.badge %></span>
                            <span class="manual-hub-doc-action"><%= meta.action %> <i class="fas fa-external-link-alt" aria-hidden="true"></i></span>
                        </a>
                        <% } %>
                        <% }) %>
                    </div>
                </article>
                <% }) %>
            </div>

            <p class="manual-hub-empty" id="manualHubEmpty" hidden>Nenhum resultado encontrado. Tente outro termo de busca.</p>

            <% } else if (page.content && page.content.sections && page.content.sections.length) { %>
                <% page.content.sections.forEach(function(section) { %>
                    <div class="client-docs-group">
                        <h2 class="client-docs-group-title"><%= section.title %></h2>
                        <ul class="client-docs-list">
                            <% (section.documents || []).forEach(function(doc) { %>
                                <% const isPdf = /\.pdf($|\?)/i.test(doc.href || ''); %>
                                <li>
                                    <a href="<%= doc.href %>" class="client-docs-link" target="_blank" rel="noopener noreferrer">
                                        <span class="client-docs-link-icon<%= isPdf ? '' : ' is-html' %>"><i class="fas <%= isPdf ? 'fa-file-pdf' : 'fa-file-lines' %>" aria-hidden="true"></i></span>
                                        <span class="client-docs-link-text"><%= doc.title %></span>
                                        <span class="client-docs-link-action"><%= isPdf ? 'Abrir PDF' : 'Abrir documento' %> <i class="fas fa-external-link-alt" aria-hidden="true"></i></span>
                                    </a>
                                </li>
                            <% }); %>
                        </ul>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </section>

    <%- include('includes/footer', { footer }) %>

    <a href="<%= typeof whatsappUrl !== 'undefined' ? whatsappUrl : 'https://api.whatsapp.com/send?phone=556121958300' %>" class="whatsapp-float" target="_blank" rel="noopener" aria-label="WhatsApp">
        <i class="fab fa-whatsapp"></i>
    </a>
    <script src="/main.js"></script>
    <% if (typeof isManualHub !== 'undefined' && isManualHub) { %>
    <script>
    (function () {
        const searchInput = document.getElementById('manualHubSearch');
        const cards = Array.from(document.querySelectorAll('.manual-hub-card'));
        const countEl = document.getElementById('manualHubCount');
        const emptyEl = document.getElementById('manualHubEmpty');
        const jumpEl = document.getElementById('manualHubJump');
        if (!searchInput || !cards.length) return;

        function setExpanded(card, expanded) {
            const btn = card.querySelector('.manual-hub-card-toggle');
            const panel = card.querySelector('.manual-hub-card-panel');
            if (!btn || !panel) return;
            btn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
            panel.hidden = !expanded;
        }

        document.querySelectorAll('.manual-hub-card-toggle').forEach(function (btn) {
            btn.addEventListener('click', function () {
                const card = btn.closest('.manual-hub-card');
                const isOpen = btn.getAttribute('aria-expanded') === 'true';
                setExpanded(card, !isOpen);
            });
        });

        document.querySelectorAll('.manual-hub-jump-link').forEach(function (link) {
            link.addEventListener('click', function (e) {
                const id = link.getAttribute('href').slice(1);
                const card = document.getElementById(id);
                if (!card) return;
                e.preventDefault();
                setExpanded(card, true);
                card.scrollIntoView({ behavior: 'smooth', block: 'start' });
                if (history.replaceState) history.replaceState(null, '', '#' + id);
            });
        });

        if (window.location.hash) {
            const target = document.querySelector(window.location.hash);
            if (target && target.classList.contains('manual-hub-card')) {
                setExpanded(target, true);
            }
        }

        function filterCards() {
            const query = searchInput.value.trim().toLowerCase();
            let visible = 0;
            cards.forEach(function (card) {
                const keywords = card.getAttribute('data-manual-keywords') || card.getAttribute('data-manual-title') || '';
                const match = !query || keywords.includes(query);
                card.hidden = !match;
                if (match) {
                    visible += 1;
                    if (query) setExpanded(card, true);
                }
            });
            if (jumpEl) jumpEl.hidden = Boolean(query);
            if (countEl) {
                countEl.textContent = visible === cards.length
                    ? visible + ' empreendimentos'
                    : visible + ' de ' + cards.length + ' empreendimentos';
            }
            if (emptyEl) emptyEl.hidden = visible > 0;
        }

        searchInput.addEventListener('input', filterCards);
    })();
    </script>
    <% } %>
</body>
</html>
