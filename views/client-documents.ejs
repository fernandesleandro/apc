<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= page.title %></title>
    <meta name="description" content="<%= page.description %>">
    <link rel="canonical" href="<%= requestUrl %>">
    <meta property="og:title" content="<%= page.title %>">
    <meta property="og:description" content="<%= page.description %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= requestUrl %>">
    <meta property="og:locale" content="pt_BR">
    <%- include('includes/meta-og') %>
    <link rel="stylesheet" href="/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

    <%- include('includes/header', { nav, active }) %>

    <section class="page-banner" style="background: linear-gradient(rgba(0,11,44,0.88), rgba(0,7,20,0.96)), url('https://images.unsplash.com/photo-1556761175-4b46a572b786?auto=format&fit=crop&w=1920&q=80') center/cover no-repeat;">
        <div class="container">
            <h1><%= page.hero.title %></h1>
            <p><%= page.hero.subtitle %></p>
        </div>
    </section>

    <section class="client-docs-section">
        <div class="container">
            <div class="client-docs-intro">
                <% if (page.content && page.content.intro) { %>
                    <p><%= page.content.intro %></p>
                <% } %>
                <% if (page.content && page.content.backHref) { %>
                    <a href="<%= page.content.backHref %>" class="client-docs-back"><i class="fas fa-arrow-left" aria-hidden="true"></i> <%= page.content.backLabel || 'Voltar' %></a>
                <% } %>
            </div>

            <% if (page.content && page.content.sections && page.content.sections.length) { %>
                <% page.content.sections.forEach(function(section) { %>
                    <div class="client-docs-group">
                        <h2 class="client-docs-group-title"><%= section.title %></h2>
                        <ul class="client-docs-list">
                            <% (section.documents || []).forEach(function(doc) { %>
                                <% const isPdf = /\.pdf($|\?)/i.test(doc.href || ''); %>
                                <li>
                                    <a href="<%= doc.href %>" class="client-docs-link" target="_blank" rel="noopener noreferrer">
                                        <span class="client-docs-link-icon<%= isPdf ? '' : ' is-html' %>"><i class="fas <%= isPdf ? 'fa-file-pdf' : 'fa-file-lines' %>" aria-hidden="true"></i></span>
                                        <span class="client-docs-link-text"><%= doc.title %></span>
                                        <span class="client-docs-link-action"><%= isPdf ? 'Abrir PDF' : 'Abrir documento' %> <i class="fas fa-external-link-alt" aria-hidden="true"></i></span>
                                    </a>
                                </li>
                            <% }); %>
                        </ul>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </section>

    <%- include('includes/footer', { footer }) %>

    <a href="<%= typeof whatsappUrl !== 'undefined' ? whatsappUrl : 'https://api.whatsapp.com/send?phone=556121958300' %>" class="whatsapp-float" target="_blank" rel="noopener" aria-label="WhatsApp">
        <i class="fab fa-whatsapp"></i>
    </a>
    <script src="/main.js"></script>
</body>
</html>
