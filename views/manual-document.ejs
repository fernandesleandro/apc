<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= manual.docTitle %> — <%= manual.sectionTitle %> | AP Construções</title>
    <meta name="description" content="<%= manual.docTitle %> do empreendimento <%= manual.sectionTitle %>">
    <link rel="canonical" href="<%= requestUrl %>">
    <link rel="stylesheet" href="/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

    <%- include('includes/header', { nav, active }) %>

    <section class="page-banner page-banner--compact">
        <div class="container">
            <p class="manual-reader-eyebrow"><%= manual.sectionTitle %></p>
            <h1><%= manual.docTitle %></h1>
            <p class="manual-reader-subtitle"><%= manual.chapterCount %> tópico<%= manual.chapterCount === 1 ? '' : 's' %></p>
        </div>
    </section>

    <section class="manual-reader-section">
        <div class="container">
            <nav class="manual-reader-nav" aria-label="Navegação do manual">
                <a href="/acesso-cliente/manual-proprietario" class="manual-reader-back">
                    <i class="fas fa-arrow-left" aria-hidden="true"></i> Todos os manuais
                </a>
                <a href="/acesso-cliente/manual-proprietario#manual-<%= manual.sectionSlug %>" class="manual-reader-back manual-reader-back--secondary">
                    <i class="fas fa-building" aria-hidden="true"></i> <%= manual.sectionTitle %>
                </a>
            </nav>

            <div class="manual-tree-layout">
                <aside class="manual-tree-sidebar" aria-label="Tópicos do manual">
                    <div class="manual-tree-sidebar-head">
                        <h2 class="manual-tree-sidebar-title"><i class="fas fa-sitemap" aria-hidden="true"></i> Tópicos</h2>
                        <span class="manual-tree-sidebar-count"><%= manual.chapterCount %></span>
                    </div>
                    <input type="search" id="manualTreeSearch" class="manual-tree-search" placeholder="Filtrar tópicos…" autocomplete="off" aria-label="Filtrar tópicos">
                    <nav class="manual-tree-nav">
                        <ul class="manual-tree" id="manualTree">
                            <% const firstSlug = firstChapter ? firstChapter.slug : (toc.length ? toc[0].slug : ''); %>
                            <% tree.forEach(function(node) { %>
                                <% if (node.type === 'section') { %>
                                <li class="manual-tree-section" data-tree-section>
                                    <button type="button" class="manual-tree-section-toggle" aria-expanded="true">
                                        <i class="fas fa-folder-open manual-tree-section-icon" aria-hidden="true"></i>
                                        <span><%= node.title %></span>
                                        <i class="fas fa-chevron-down manual-tree-section-chevron" aria-hidden="true"></i>
                                    </button>
                                    <ul class="manual-tree-section-children">
                                        <% node.children.forEach(function(topic) { %>
                                        <li class="manual-tree-item" data-tree-title="<%= String(topic.title || '').toLowerCase() %>">
                                            <button type="button" class="manual-tree-node<%= topic.slug === firstSlug ? ' is-active' : '' %>" data-slug="<%= topic.slug %>" data-title="<%= topic.title %>">
                                                <i class="fas fa-file-lines" aria-hidden="true"></i>
                                                <span><%= topic.title %></span>
                                            </button>
                                        </li>
                                        <% }) %>
                                    </ul>
                                </li>
                                <% } else { %>
                                <li class="manual-tree-item" data-tree-title="<%= String(node.title || '').toLowerCase() %>">
                                    <button type="button" class="manual-tree-node<%= node.slug === firstSlug ? ' is-active' : '' %>" data-slug="<%= node.slug %>" data-title="<%= node.title %>">
                                        <i class="fas fa-file-lines" aria-hidden="true"></i>
                                        <span><%= node.title %></span>
                                    </button>
                                </li>
                                <% } %>
                            <% }) %>
                        </ul>
                    </nav>
                </aside>

                <div class="manual-tree-main">
                    <header class="manual-tree-content-head">
                        <h2 class="manual-tree-content-title" id="manualContentTitle"><%= firstChapter ? firstChapter.title : manual.docTitle %></h2>
                    </header>
                    <article class="manual-reader-content manual-tree-content-body" id="manualContentBody">
                        <% if (firstChapter) { %>
                        <div class="manual-tree-panel" id="panel-<%= firstChapter.slug %>" data-slug="<%= firstChapter.slug %>" data-title="<%= firstChapter.title %>" data-loaded="true">
                            <%- firstChapter.html %>
                        </div>
                        <% } %>
                    </article>
                </div>
            </div>
        </div>
    </section>

    <%- include('includes/footer', { footer }) %>

    <a href="<%= typeof whatsappUrl !== 'undefined' ? whatsappUrl : 'https://api.whatsapp.com/send?phone=556121958300' %>" class="whatsapp-float" target="_blank" rel="noopener" aria-label="WhatsApp">
        <i class="fab fa-whatsapp"></i>
    </a>
    <script src="/main.js"></script>
    <script>
    (function () {
        const apiBase = '<%= chapterApiBase %>';
        const contentBody = document.getElementById('manualContentBody');
        const titleEl = document.getElementById('manualContentTitle');
        const searchInput = document.getElementById('manualTreeSearch');
        const nodes = Array.from(document.querySelectorAll('.manual-tree-node'));
        const loadedSlugs = new Set();
        <% if (firstChapter) { %>loadedSlugs.add('<%= firstChapter.slug %>');<% } %>

        const loadingHtml = '<div class="manual-tree-loading" role="status"><i class="fas fa-spinner fa-spin" aria-hidden="true"></i> Carregando tópico…</div>';
        const errorHtml = '<p class="manual-tree-error">Não foi possível carregar este tópico. <button type="button" class="manual-tree-retry">Tentar novamente</button></p>';

        function getPanel(slug) {
            return document.getElementById('panel-' + slug);
        }

        function hideAllPanels() {
            contentBody.querySelectorAll('.manual-tree-panel').forEach(function (panel) {
                panel.hidden = true;
            });
        }

        function setActiveNode(slug) {
            nodes.forEach(function (node) {
                node.classList.toggle('is-active', node.getAttribute('data-slug') === slug);
            });
        }

        function updateTitle(title) {
            if (titleEl && title) titleEl.textContent = title;
        }

        function showPanel(panel, slug, title) {
            hideAllPanels();
            panel.hidden = false;
            setActiveNode(slug);
            updateTitle(title || panel.getAttribute('data-title'));
            if (history.replaceState) {
                history.replaceState(null, '', '#' + slug);
            }
            if (window.matchMedia('(max-width: 900px)').matches) {
                contentBody.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        }

        async function loadTopic(slug, title) {
            const node = nodes.find(function (btn) { return btn.getAttribute('data-slug') === slug; });
            const resolvedTitle = title || (node && node.getAttribute('data-title')) || '';
            let panel = getPanel(slug);

            if (!panel) {
                panel = document.createElement('div');
                panel.className = 'manual-tree-panel';
                panel.id = 'panel-' + slug;
                panel.dataset.slug = slug;
                panel.dataset.title = resolvedTitle;
                contentBody.appendChild(panel);
            }

            showPanel(panel, slug, resolvedTitle);

            if (loadedSlugs.has(slug)) return;

            panel.innerHTML = loadingHtml;
            panel.dataset.loaded = 'false';

            try {
                const response = await fetch(apiBase + '/' + encodeURIComponent(slug), {
                    headers: { Accept: 'application/json' }
                });
                if (!response.ok) throw new Error('HTTP ' + response.status);
                const data = await response.json();
                panel.innerHTML = data.html;
                panel.dataset.title = data.title;
                panel.dataset.loaded = 'true';
                loadedSlugs.add(slug);
                updateTitle(data.title);
            } catch (err) {
                panel.innerHTML = errorHtml;
                panel.dataset.loaded = 'false';
                const retryBtn = panel.querySelector('.manual-tree-retry');
                if (retryBtn) {
                    retryBtn.addEventListener('click', function () {
                        loadTopic(slug, resolvedTitle);
                    });
                }
            }
        }

        nodes.forEach(function (btn) {
            btn.addEventListener('click', function () {
                loadTopic(btn.getAttribute('data-slug'), btn.getAttribute('data-title'));
            });
        });

        document.querySelectorAll('.manual-tree-section-toggle').forEach(function (btn) {
            btn.addEventListener('click', function () {
                const section = btn.closest('.manual-tree-section');
                const expanded = btn.getAttribute('aria-expanded') === 'true';
                btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
                section.classList.toggle('is-collapsed', expanded);
                const icon = btn.querySelector('.manual-tree-section-icon');
                if (icon) {
                    icon.classList.toggle('fa-folder-open', !expanded);
                    icon.classList.toggle('fa-folder', expanded);
                }
            });
        });

        if (searchInput) {
            searchInput.addEventListener('input', function () {
                const query = searchInput.value.trim().toLowerCase();
                document.querySelectorAll('.manual-tree-item[data-tree-title]').forEach(function (item) {
                    const match = !query || (item.getAttribute('data-tree-title') || '').includes(query);
                    item.hidden = !match;
                });
                document.querySelectorAll('.manual-tree-section[data-tree-section]').forEach(function (section) {
                    const visible = Array.from(section.querySelectorAll('.manual-tree-item[data-tree-title]')).some(function (item) { return !item.hidden; });
                    section.hidden = !visible;
                    if (visible && query) {
                        section.classList.remove('is-collapsed');
                        const toggle = section.querySelector('.manual-tree-section-toggle');
                        if (toggle) toggle.setAttribute('aria-expanded', 'true');
                    }
                });
            });
        }

        const hashSlug = window.location.hash ? window.location.hash.slice(1) : '';
        const initialSlug = hashSlug || (nodes[0] && nodes[0].getAttribute('data-slug'));
        if (initialSlug) {
            const initialNode = nodes.find(function (btn) { return btn.getAttribute('data-slug') === initialSlug; });
            if (hashSlug && !loadedSlugs.has(hashSlug)) {
                loadTopic(initialSlug, initialNode && initialNode.getAttribute('data-title'));
            } else if (hashSlug) {
                const panel = getPanel(initialSlug);
                if (panel) showPanel(panel, initialSlug);
            } else if (!loadedSlugs.has(initialSlug)) {
                loadTopic(initialSlug, initialNode && initialNode.getAttribute('data-title'));
            } else {
                const panel = getPanel(initialSlug);
                if (panel) showPanel(panel, initialSlug);
            }
        }
    })();
    </script>
</body>
</html>
