<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= page.title %></title>
    <meta name="description" content="AP Construções entrega projetos residenciais e corporativos de alto padrão em Brasília.">
    <link rel="canonical" href="<%= requestUrl %>">
    <meta property="og:title" content="<%= page.title %>">
    <meta property="og:description" content="AP Construções entrega projetos residenciais e corporativos de alto padrão em Brasília.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= requestUrl %>">
    <meta property="og:locale" content="pt_BR">
    <%- include('includes/meta-og') %>
    <link rel="stylesheet" href="/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <%- include('includes/header', { nav, active }) %>

    <section class="hero" style="background: linear-gradient(rgba(0, 17, 44, 0.7), rgba(0, 7, 20, 0.88)), url('https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=1200&q=80') center/cover no-repeat;">
        <div class="container">
            <h1 class="hero-title"><%= page.hero.title %></h1>
            <p class="hero-subtitle"><%= page.hero.subtitle %></p>
            <div class="hero-buttons">
                <a href="/contato" class="btn btn-filled">Fale Conosco <i class="fas fa-arrow-right" style="margin-left:5px;"></i></a>
                <a href="#obras" class="btn btn-outline-white">Ver Empreendimentos</a>
            </div>
        </div>
    </section>

    <section id="servicos" class="services-section">
        <div class="container">
            <span class="section-tag"><%= servicesSection.tag %></span>
            <h2 class="section-title title-light"><%= servicesSection.title %></h2>
            <div class="services-grid">
                <% servicesSection.items.forEach(function(item) { %>
                    <% const iconClass = (item.icon || 'fa-building').replace(/^fas?\s+/, ''); %>
                    <div class="service-card">
                        <div class="service-icon"><i class="fas <%= iconClass %>"></i></div>
                        <h3><%= item.title %></h3>
                        <p><%= item.description %></p>
                    </div>
                <% }) %>
            </div>
        </div>
    </section>

    <section id="obras" class="projects-section">
        <div class="container">
            <span class="section-tag">Destaques</span>
            <h2 class="section-title">Nossos Empreendimentos</h2>
            <p style="color: var(--text-muted); margin-top: -10px; margin-bottom: 40px; font-size: 1.1rem;">Conheça lançamentos inspirados nas melhores tendências globais de design urbano.</p>
            <%- include('includes/projects-filters', { categoryOptions, statusOptions }) %>
            <div class="projects-grid">
                <% if (projects && projects.length) { %>
                    <% projects.forEach(project => { %>
                        <%- include('includes/project-card', { project }) %>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </section>

    <%- include('includes/footer', { footer }) %>

    <a href="<%= typeof whatsappUrl !== 'undefined' ? whatsappUrl : 'https://api.whatsapp.com/send?phone=556121958300' %>" class="whatsapp-float" target="_blank" rel="noopener" aria-label="WhatsApp">
        <i class="fab fa-whatsapp"></i>
    </a>
    <script src="/main.js"></script>
</body>
</html>
