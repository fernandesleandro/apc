<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <% const pageTitle = typeof listingTitle !== 'undefined' ? listingTitle : 'Empreendimentos'; %>
    <title><%= pageTitle %> | AP Construções</title>
    <meta name="description" content="<%= typeof listingSubtitle !== 'undefined' ? listingSubtitle : 'Conheça os principais empreendimentos da AP Construções em Brasília.' %>">
    <link rel="canonical" href="<%= requestUrl %>">
    <meta property="og:title" content="<%= pageTitle %> | AP Construções">
    <meta property="og:description" content="<%= typeof listingSubtitle !== 'undefined' ? listingSubtitle : 'Conheça os principais empreendimentos da AP Construções em Brasília.' %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= requestUrl %>">
    <meta property="og:locale" content="pt_BR">
    <%- include('includes/meta-og') %>
    <link rel="stylesheet" href="/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <% if (typeof bannerImage !== 'undefined' && bannerImage) { %>
    <link rel="preload" as="image" href="<%= bannerImage %>">
    <% } %>
</head>
<body>
    <a href="#main-content" class="skip-link">Pular para o conteúdo</a>
    <%- include('includes/header', { nav, active }) %>

    <main id="main-content">

    <section class="page-banner<%= typeof bannerImage !== 'undefined' && bannerImage ? ' page-banner--local' : ' page-banner--gradient' %>"<% if (typeof bannerImage !== 'undefined' && bannerImage) { %> style="background-image: linear-gradient(rgba(0,11,44,0.85), rgba(0,7,20,0.95)), url('<%= bannerImage %>')"<% } %>>
        <div class="container">
            <h1><%= pageTitle %></h1>
            <p><%= typeof listingSubtitle !== 'undefined' ? listingSubtitle : 'Conheça os principais empreendimentos realizados pela AP Construções' %></p>
        </div>
    </section>

    <section id="obras" class="projects-section"<% if (typeof presetStatus !== 'undefined' && presetStatus) { %> data-initial-status="<%= presetStatus %>"<% } %>>
        <div class="container">
            <span class="section-tag">Destaques</span>
            <h2 class="section-title"><%= typeof sectionTitle !== 'undefined' ? sectionTitle : 'Empreendimentos' %></h2>
            <p style="color: var(--text-muted); margin-top: -10px; margin-bottom: 40px; font-size: 1.1rem;"><%= typeof sectionIntro !== 'undefined' ? sectionIntro : 'Conheça lançamentos inspirados nas melhores tendências globais de design urbano.' %></p>

            <%- include('includes/projects-filters', { categoryOptions, statusOptions, hideStatusFilter: typeof hideStatusFilter !== 'undefined' ? hideStatusFilter : false, presetStatus: typeof presetStatus !== 'undefined' ? presetStatus : '' }) %>
            <div class="projects-grid">
                <% if (projects && projects.length) { %>
                    <% projects.forEach(function(project, index) { %>
                    <%- include('includes/project-card', { project, eagerImage: index === 0 }) %>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </section>

    </main>

    <%- include('includes/footer', { footer }) %>

    <a href="<%= typeof whatsappUrl !== 'undefined' ? whatsappUrl : 'https://api.whatsapp.com/send?phone=556121958300' %>" class="whatsapp-float" target="_blank" rel="noopener" aria-label="WhatsApp">
        <i class="fab fa-whatsapp"></i>
    </a>
    <script src="/main.js"></script>

</body>
</html>
