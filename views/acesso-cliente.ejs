<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= page.title %></title>
    <meta name="description" content="<%= page.description %>">
    <link rel="canonical" href="<%= requestUrl %>">
    <meta property="og:title" content="<%= page.title %>">
    <meta property="og:description" content="<%= page.description %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= requestUrl %>">
    <meta property="og:locale" content="pt_BR">
    <%- include('includes/meta-og') %>
    <link rel="stylesheet" href="/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

    <%- include('includes/header', { nav, active }) %>

    <section class="page-banner page-banner--atendimento">
        <div class="container">
            <h1><%= page.hero.title %></h1>
            <p><%= page.hero.subtitle %></p>
        </div>
    </section>

    <section class="portal-hub-section">
        <div class="container">
            <div class="portal-hub-intro">
                <span class="section-tag">Portal do Cliente</span>
                <h2 class="section-title">Como podemos ajudar?</h2>
                <% if (page.content && page.content.intro) { %>
                    <p><%= page.content.intro %></p>
                <% } %>
            </div>

            <div class="portal-hub-grid">
                <% if (page.content && page.content.services && page.content.services.length) { %>
                    <% page.content.services.forEach(function(service) { %>
                        <% const iconClass = (service.icon || 'fa-circle-info').replace(/^fas?\s+/, ''); %>
                        <% const isDisabled = Boolean(service.disabled); %>
                        <% const isExternal = !isDisabled && (service.external || (service.href && /^https?:\/\//i.test(service.href))); %>
                        <% if (isDisabled) { %>
                            <div class="portal-hub-card is-disabled" aria-disabled="true">
                                <span class="portal-hub-badge"><%= service.disabledLabel || 'Indisponível' %></span>
                                <div class="portal-hub-icon"><i class="fas <%= iconClass %>" aria-hidden="true"></i></div>
                                <h3><%= service.title %></h3>
                                <p><%= service.description %></p>
                                <span class="portal-hub-cta is-muted"><%= service.disabledLabel || 'Indisponível' %></span>
                            </div>
                        <% } else { %>
                            <a href="<%= service.href || '/contato' %>" class="portal-hub-card"<% if (isExternal) { %> target="_blank" rel="noopener noreferrer"<% } %>>
                                <div class="portal-hub-icon"><i class="fas <%= iconClass %>" aria-hidden="true"></i></div>
                                <h3><%= service.title %></h3>
                                <p><%= service.description %></p>
                                <span class="portal-hub-cta"><%= service.cta || 'Acessar' %> <i class="fas <%= isExternal ? 'fa-external-link-alt' : 'fa-arrow-right' %>" aria-hidden="true"></i></span>
                            </a>
                        <% } %>
                    <% }); %>
                <% } %>
            </div>
        </div>
    </section>

    <%- include('includes/footer', { footer }) %>

    <a href="<%= typeof whatsappUrl !== 'undefined' ? whatsappUrl : 'https://api.whatsapp.com/send?phone=556121958300' %>" class="whatsapp-float" target="_blank" rel="noopener" aria-label="WhatsApp">
        <i class="fab fa-whatsapp"></i>
    </a>
    <script src="/main.js"></script>
</body>
</html>
