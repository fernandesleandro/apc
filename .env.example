# URL pública do site (sitemap, links canônicos)
SITE_URL=https://www.apconstrucoes.com.br

# Sessão do admin (gravada no MongoDB — sobrevive a reinício do nodemon)
SESSION_SECRET=altere-esta-chave-em-producao
# Só true em HTTPS de produção; em localhost deixe comentado ou false
# COOKIE_SECURE=false

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/ap_construcoes

# WhatsApp (somente números, com DDI)
WHATSAPP_PHONE=556121958300

# E-mail do formulário de contato (opcional — se SMTP não estiver configurado, mensagens ficam salvas no MongoDB)
CONTACT_EMAIL=contato@apconstrucoes.com.br

# SMTP (credenciais ficam SOMENTE no servidor — nunca no front-end)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AP Construções <contato@apconstrucoes.com.br>"

# Portal do Cliente (Sienge) — boletos e acompanhamento de obra
CLIENT_PORTAL_SIENGE_URL=https://apconstrucoes-portalcliente.sienge.com.br/PortalCliente/Welcome.do
# Opcional: substituir link de manutenção (padrão: portobsb institucional)
# CLIENT_PORTAL_ODOO_URL=
# CLIENT_MANUTENCAO_URL=http://www.portobsb.com.br/institucional/
# CLIENT_MANUAL_URL=/acesso-cliente/manual-proprietario
# CLIENT_CONVENCAO_URL=http://www.portobsb.com.br/institucional/porto_conv1.php
# CLIENT_PERICIA_URL=http://www.portobsb.com.br/institucional/oly_perz.php
